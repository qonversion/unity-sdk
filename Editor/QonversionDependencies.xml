      <iosPod name="QonversionSandwich" version="7.9.0" />
    </iosPods>
    <remoteSwiftPackage url="https://github.com/qonversion/sandwich-sdk.git"
                        version="7.10.0"
                        upToNextMajor="true">
      <swiftPackage name="QonversionSandwich" replacesPod="QonversionSandwich" />
    </remoteSwiftPackage>
</dependencies>
